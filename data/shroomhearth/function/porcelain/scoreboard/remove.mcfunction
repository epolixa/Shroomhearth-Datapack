# Used to check if another Player's Porcelain Amphora is too close while attempting to use a Porcelain Amphora
scoreboard objectives remove nearby_porcelain_amphora

# Used to check if there are monsters nearby while attempting to use a Porcelain Amphora
scoreboard objectives remove nearby_monster

# Tracks UUID data of a Porcelain Amphora's parent Player
scoreboard objectives remove porcelain_amphora_uuid_1
scoreboard objectives remove porcelain_amphora_uuid_2
scoreboard objectives remove porcelain_amphora_uuid_3
scoreboard objectives remove porcelain_amphora_uuid_4

# Used to check if a Player has a Porcelain Amphora in their inventory
scoreboard objectives remove has_porcelain_amphora